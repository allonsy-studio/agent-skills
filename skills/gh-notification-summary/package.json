{
  "private": true,
  "name": "@allons-y/skill-gh-notification-summary",
  "version": "1.3.0",
  "description": "Review, summarize, and manage GitHub notifications via an interactive local dashboard. Unsubscribe from noisy threads, mark individual notifications or your whole inbox as done, all from a single prompt.",
  "type": "module",
  "skill": {
    "category": "GitHub",
    "runtime": "node",
    "triggers": [
      "check my GitHub notifications",
      "/unsub <number>",
      "mark all done",
      "clear my GitHub inbox",
      "any request to triage, dismiss, or act on GitHub notifications"
    ]
  },
  "bin": {
    "gh-notifications": "bin/cli.js"
  },
  "scripts": {
    "ci:test": "yarn coverage",
    "coverage": "c8 yarn test",
    "format": "yarn package:format",
    "lint": "yarn package:lint",
    "preview": "gh-notifications fetch",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@octokit/auth-oauth-device": "^8.0.3",
    "@octokit/rest": "^22.0.0",
    "@prettier/sync": "^0.6.1",
    "colors": "^1.4.0",
    "dotenv": "^17.0.0",
    "inquirer": "^13.4.3",
    "markdown-it": "^14.1.1",
    "nunjucks": "^3.2.4",
    "randomcolor": "^0.6.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3"
  }
}
