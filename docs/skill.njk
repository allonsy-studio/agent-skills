---
layout: foundation.njk
theme:
  color: "#d22d6f"
  fonts: ["Roboto", "Lato", "Helvetica Neue"]
pagination:
  data: site.skills
  size: 1
  alias: skill
permalink: "skills/{{ skill.name }}/index.html"
eleventyComputed:
  title: "{{ skill.name }}"
  tagline_short: "{{ skill.description | truncate(60, true) }}"
  description: "{{ skill.description }}"
---

{% css %}{% include "./skill.css" %}{% endcss %}
{% from "skill-chips.njk" import skillChips %}

{# The hero is full-bleed so its glow fades out in open space instead of being
   clipped at the container edge; only the content is container-constrained. #}
<header class="skill-hero">
	<div class="container">
		<p class="breadcrumb"><a href="/">{{ site.title }}</a> <span aria-hidden="true">/</span> <a href="/#skills">skills</a></p>
		<h1>{{ skill.name }}</h1>
		<p class="lede">{{ skill.description }}</p>
		{{ skillChips(skill, true) }}
		<p class="btn-group">
			<a class="btn primary" href="#install">Install this skill</a>
			<a class="btn" href="{{ skill.url }}"><span class="fa-brands fa-github" aria-hidden="true"></span> View source</a>
			{% if skill.previewUrl %}<a class="btn" href="{{ skill.previewUrl }}"><span class="fa-solid fa-up-right-from-square" aria-hidden="true"></span> Preview skill interface</a>{% endif %}
		</p>
	</div>
</header>

<main id="main" class="container skill-detail">
	<div class="skill-cols">
		<aside id="install" class="install-aside" aria-labelledby="install-heading">
			<header>
				<h2 id="install-heading">Install</h2>
				<h3>Claude Code</h3>
			</header>
			<div class="install-option">
				{% highlight "shell" %}/plugin marketplace add {{ site.repo.slug }}
/plugin install {{ skill.name }}@{{ site.marketplace_name }}{% endhighlight %}
			</div>
			<div>
				<a class="cta" href="{{ skill.url }}"><span class="fa-brands fa-github" aria-hidden="true"></span> View source</a>
			</div>
		</aside>

		<div class="skill-flow">
			<section id="use" aria-labelledby="use-heading" class="layout stacked">
				<header>
					<h2 id="use-heading">
						How to use it
						<a class="anchor" href="#use" aria-label="Permalink to How to use it">#</a>
					</h2>
					<p>Once installed, this skill activates automatically when your prompt matches one of its triggers.</p>
				</header>
				{% if skill.commands.length > 0 -%}
				<div class="content">
					<h3>Commands</h3>
					<ul class="snippet-list">
						{% for command in skill.commands %}<li><code>{{ command }}</code></li>{% endfor %}
					</ul>
				</div>
				{%- endif %}
				{% if skill.triggers.length > 0 -%}
				<div class="content">
					<h3>Try saying</h3>
					<ul class="snippet-list">
						{% for trigger in skill.triggers %}<li><code>{{ trigger }}</code></li>{% endfor %}
					</ul>
				</div>
				{%- endif %}
			</section>

			{% if skill.treeHtml -%}
			<section id="structure" class="structure" aria-labelledby="structure-heading">
				<header>
					<h2 id="structure-heading">
						Folder structure
						<a class="anchor" href="#structure" aria-label="Permalink to Folder structure">#</a>
					</h2>
					<p>Everything in this skill's source directory — scripts, references, and the tests and evals that back it. The installer copies the runtime files into your skills directory; the tests and evals stay in the repo.</p>
				</header>
				<pre class="skill-tree language-treeview"><code class="language-treeview">{{ skill.treeHtml | safe }}</code></pre>
			</section>
			{%- endif %}

			{% if skill.overviewHtml -%}
			<section id="docs" aria-labelledby="docs-heading" class="layout stacked">
				<header>
					<h2 id="docs-heading">
						Full skill instructions
						<a class="anchor" href="#docs" aria-label="Permalink to Full skill instructions">#</a>
					</h2>
					<p>This is the <code>SKILL.md</code> the agent reads when the skill activates. <a href="{{ skill.url }}">View the source on GitHub</a>.</p>
				</header>
				<div class="prose">
					{{ skill.overviewHtml | safe }}
				</div>
			</section>
			{%- endif %}
		</div>
	</div>

	{% if site.skills.length > 1 -%}
	<section id="more" aria-labelledby="more-heading" class="layout stacked">
		<header>
			<h2 id="more-heading">
				Other skills
				<a class="anchor" href="#more" aria-label="Permalink to Other skills">#</a>
			</h2>
		</header>
		<article class="layout grid">
			{% for other in site.skills -%}{% if other.name != skill.name -%}
			<a class="card" href="{{ other.detailUrl }}">
				<div class="header">
					<h3>{{ other.name }}</h3>
					{{ skillChips(other) }}
				</div>
				<div class="body">
					<p>{{ other.description | truncate(140) }}</p>
				</div>
				<div class="footer">
					<p class="cta">Learn more</p>
				</div>
			</a>
			{%- endif %}{%- endfor %}
		</article>
	</section>
	{%- endif %}
</main>
