{
  "name": "@allons-y/agent-skills",
  "version": "0.0.0",
  "description": "A collection of skills designed for Claude to streamline processes and reduce token-use",
  "license": "Apache-2.0",
  "author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.llc)",
  "homepage": "https://github.com/castastrophe/agent-skills#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/castastrophe/agent-skills.git"
  },
  "bugs": {
    "url": "https://github.com/castastrophe/agent-skills/issues"
  },
  "type": "module",
  "main": "index.js",
  "bin": "bin/install.js",
  "files": [
    ".claude-plugin/",
    "bin/",
    "skills/",
    "AGENTS.md"
  ],
  "scripts": {
    "check": "yarn workspaces foreach -A run check",
    "ci:test": "yarn workspaces foreach -A run ci:test",
    "coverage": "node scripts/run-tests.js --coverage-only",
    "evals": "node scripts/run-evals.js",
    "format": "yarn workspaces foreach -A run format",
    "generate:marketplace": "node scripts/generate-plugin-manifest.js",
    "postinstall": "husky && envoy || true",
    "lint": "yarn workspaces foreach -A run lint",
    "package:format": "prettier --cache --write package.json */*.js *.{js,json,yml,md} && eslint --no-error-on-unmatched-pattern --no-warn-ignored --cache --fix *.{js,json,yml,md} */*.{js,json,yml,md}",
    "package:lint": "prettier --cache --check package.json */*.js *.{js,json,yml,md} && eslint --no-error-on-unmatched-pattern --no-warn-ignored --cache *.{js,json,yml,md} */*.{js,json,yml,md}",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "prepublishOnly": "yarn generate:marketplace",
    "release": "semantic-release",
    "security": "yarn workspaces foreach -A run security",
    "test": "node scripts/run-tests.js",
    "ts:check": "tsc --noEmit"
  },
  "workspaces": [
    "skills/*"
  ],
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@allons-y/envoy": "^1.1.0",
    "@anthropic-ai/sdk": "^0.96.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "colors": "^1.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "execa": "^9.6.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "listr2": "^10.2.1",
    "pinst": "^3.0.0",
    "prettier": "^3.8.3",
    "prettier-package-json": "^2.8.0",
    "semantic-release": "^25.0.3",
    "text-table": "^0.2.0",
    "yargs": "^18.0.0"
  },
  "keywords": [
    "agent-skills",
    "agents",
    "ai",
    "anthropic",
    "automation",
    "claude",
    "claude-code"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/castastrophe"
    },
    {
      "type": "buy-me-a-coffee",
      "url": "https://www.buymeacoffee.com/castastrophe"
    }
  ],
  "packageManager": "yarn@4.13.0"
}
